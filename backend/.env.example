# Copy this to .env and fill in your values

# MySQL
MYSQL_URL=mysql+pymysql://root:YourPassword@localhost:3306/resume_rag

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG settings
CHUNK_SIZE=200
CHUNK_OVERLAP=30
TOP_K=5

# Storage paths
CHROMA_PATH=./data/chroma
UPLOAD_PATH=./data/uploads

# Max PDF size in bytes (10MB)
MAX_PDF_SIZE=10485760

# Auth / JWT
SECRET_KEY=generate-a-long-random-string-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OTP_EXPIRE_MINUTES=10

# Email (SMTP) for OTP delivery
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
